        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/courses/{{courseId}}",
              "host": [
                "{{baseUrl}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_name\": \"Java Full Stack Updated\",\n  \"course_code\": \"JAVA-FS-102\",\n  \"fees\": 30000\n}"
            }
          },
          "response": []
