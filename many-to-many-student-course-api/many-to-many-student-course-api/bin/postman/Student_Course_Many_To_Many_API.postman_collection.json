{
  "info": {
    "name": "Student Course Many-to-Many API",
    "description": "Ready-to-import collection for the many-to-many Student-Course API with database-based Basic Auth security.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{adminUsername}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{adminPassword}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "adminUsername",
      "value": "admin",
      "type": "string"
    },
    {
      "key": "adminPassword",
      "value": "admin123",
      "type": "string"
    },
    {
      "key": "userUsername",
      "value": "user",
      "type": "string"
    },
    {
      "key": "userPassword",
      "value": "user123",
      "type": "string"
    },
    {
      "key": "courseId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "studentId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Course APIs - ADMIN",
      "item": [
        {
          "name": "Create Course - Java Full Stack",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": [
                "{{baseUrl}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_name\": \"Java Full Stack\",\n  \"course_code\": \"JAVA-FS-101\",\n  \"fees\": 25000\n}"
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "let data = pm.response.json();",
                  "if (data.id) { pm.collectionVariables.set('courseId', data.id); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Course - Spring Boot",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": [
                "{{baseUrl}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_name\": \"Spring Boot\",\n  \"course_code\": \"SPRING-101\",\n  \"fees\": 18000\n}"
            }
          },
          "response": []
        },
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/courses",
              "host": [
                "{{baseUrl}}"
              ]
            }
          },
          "response": []
