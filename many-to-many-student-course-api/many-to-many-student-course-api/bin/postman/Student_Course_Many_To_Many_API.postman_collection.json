        {
          "name": "Get Courses Page",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/courses/page?pageNumber=0&pageSize=5&sortBy=id&sortDirection=asc",
              "host": [
                "{{baseUrl}}"
              ]
            }
          },
          "response": []
